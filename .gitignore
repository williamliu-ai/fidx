# Benchmark data and results (fetched/generated, not source) — EXCEPT the
# paraphrase query sets, which are LLM-generated (not seed-reproducible) and
# therefore tracked as source.
bench/data/*
!bench/data/queries-*-paraphrase.jsonl
!bench/data/queries-*-human.jsonl
bench/results/

